# ============================================
# CONFIGURACIÓN BACKEND FULLCONTROL INFORMES
# ============================================

# Entorno
NODE_ENV=development

# ============================================
# DATABASE (RDS PostgreSQL)
# ============================================
# Opción A: Variables locales (desarrollo rápido)
DB_HOST=prod-cluster-1.c1q82mcagski.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=isis
DB_USER=isis
DB_PASSWORD=mipassword

# ============================================
# AWS (Para Secrets Manager en producción)
# ============================================
# Establece a 'true' en EC2 para usar AWS Secrets Manager
USE_AWS_SECRETS=true
AWS_REGION=us-east-1
SECRET_NAME=basededatosisis

# En desarrollo, deja estos comentados. En EC2, configura credenciales IAM.
# AWS_ACCESS_KEY_ID=xxxxx
# AWS_SECRET_ACCESS_KEY=xxxxx

# ============================================
# SERVIDOR
# ============================================
API_PORT=3002

# CORS
CORS_ORIGIN=*

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
# Opciones: debug, info, warn, error

# ============================================
# INFORMES (Opcional - para futuro)
# ============================================
# API_NOMINATIM_URL=https://nominatim.openstreetmap.org
# MAX_REPORT_SIZE_MB=100

# ============================================
# RALENTI V2 - CONFIGURACIÓN HÍBRIDA
# ============================================
# Lote escalable (manual / backfill)
RALENTI_V2_LOTE_CONCURRENCY=8
RALENTI_V2_LOTE_CHUNK_SIZE=120
RALENTI_V2_LOTE_LOCK_KEY=95012026

# Refresco on-demand (panel usuario)
RALENTI_V2_ONDEMAND_CONCURRENCY=12
RALENTI_V2_ONDEMAND_FRESHNESS_MIN=5

# Fondo activo-only (casi tiempo real)
RALENTI_V2_ACTIVOS_REALTIME_MIN=5
RALENTI_V2_ACTIVOS_MAX_MOVILES=2500
RALENTI_V2_ACTIVOS_CONCURRENCY=12
RALENTI_V2_ACTIVOS_CHUNK_SIZE=200
RALENTI_V2_ACTIVOS_LOCK_KEY=95012027

# Scheduler automático backend (activo-only + retroactiva)
RALENTI_V2_AUTORUN_ENABLED=false
RALENTI_V2_AUTORUN_ACTIVE_INTERVAL_MS=240000
RALENTI_V2_AUTORUN_RETRO_INTERVAL_MS=3600000
RALENTI_V2_AUTORUN_RETRO_HOURS=72
RALENTI_V2_AUTORUN_RETRO_LOCK_KEY=95012028
RALENTI_V2_AUTORUN_RETRO_MAX_MOVILES=5000
RALENTI_V2_AUTORUN_RETRO_CONCURRENCY=8
RALENTI_V2_AUTORUN_RETRO_CHUNK_SIZE=120
