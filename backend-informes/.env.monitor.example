# ============================================================================
# MONITOR DE COMUNICACIÓN - Variables de Entorno
# ============================================================================
# Copia este archivo a .env y completa con tus valores reales

# ============================================================================
# BASE DE DATOS - Producción (usar solo si NODE_ENV=production)
# ============================================================================
# En producción, el monitor obtiene credentials de estas variables de entorno
DB_HOST=your-rds-host.rds.amazonaws.com
DB_PORT=5432
DB_NAME=rastreofullcontrol
DB_USER=your_db_user
DB_PASSWORD=your_secure_password

# ============================================================================
# BASE DE DATOS - Desarrollo (usa AWS Secrets Manager)
# ============================================================================
# En desarrollo (NODE_ENV no es 'production'), el monitor obtiene credentials de AWS Secrets
# Configurar solo si US_AWS_SECRETS=true
USE_AWS_SECRETS=false
AWS_REGION=us-east-1
SECRET_NAME=basededatosisis

# ============================================================================
# MONITOR DE COMUNICACIÓN - Configuración
# ============================================================================
NODE_ENV=development

# Habilitar el monitor
COMMUNICATION_MONITOR_ENABLED=true

# Umbrales (SIMPLIFICADO)
# La lógica es simple: si eventCount > 0 = OK, si = 0 = CRITICAL
# No se necesita configurar thresholds, pero se pueden usar en Fase 2 para refinamientos
# COMMUNICATION_THRESHOLD_WARNING=15  # (Desuso - ver código para lógica actual)
# COMMUNICATION_THRESHOLD_OK=20       # (Desuso - ver código para lógica actual)

# ============================================================================
# MONITOR DE COMUNICACIÓN - Almacenamiento de Logs
# ============================================================================

# OPCIÓN A: Amazon S3 (Recomendado en Producción)
# Los logs se guardan en: s3://bucket/communication-monitor/YYYY/MM/DD/HH/
# Estructura: Particionado por fecha/hora para easy querying
COMMUNICATION_LOG_BUCKET=rastreofullcontrol-logs
# AWS_REGION=us-east-1  (ya configurado arriba)

# OPCIÓN B: Archivo Local en Instancia (Dev/Testing)
# Los logs se guardan en: /var/log/rastreofullcontrol/communication-health.log
# NOTA: En producción con S3, esta variable se ignora
COMMUNICATION_LOG_FILE=/var/log/rastreofullcontrol/communication-health.log

# ============================================================================
# ALERTAS - Fase 2 (Envío de notificaciones)
# ============================================================================
# Email (AWS SES SMTP)
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=AKIAWN26JQQIGMZO4FUJ
SMTP_PASS=BOltgHJtBfGV1EfD7Ke8uNgjhhjK7Zxg/QxfhzpV9Mqi
SMTP_FROM=support@fullcontrolgps.com.ar
COMMUNICATION_ALERT_EMAIL=jp.sarobe@gmail.com

# WhatsApp (Twilio - Opcional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
COMMUNICATION_ALERT_WHATSAPP=whatsapp:+549XXXXXXXXX

# ============================================================================
# DEBUG
# ============================================================================
# Mostrar logs de debug
DEBUG=false

# Log level
LOG_LEVEL=info
